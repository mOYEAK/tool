page {
  background: #F7F8FA;
  padding-bottom: 120rpx;
}

.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 16rpx 32rpx;
  background: #F7F8FA;
}

.choose-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  background: #1677FF;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
}

.choose-btn::after {
  border: none;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  padding-top: 120rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
}

/* Canvas */
.page {
  height: calc(100vh - 120rpx);
  margin-top: 120rpx;
  padding-bottom: 20rpx;
}

.canvas-wrap {
  display: flex;
  justify-content: center;
  padding: 20rpx 20rpx 0;
}

.watermark-canvas {
  border-radius: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(20, 28, 40, 0.08);
}

/* Control Panel */
.control-panel {
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
}

.control-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.control-label {
  width: 150rpx;
  color: #333333;
  font-size: 26rpx;
  flex-shrink: 0;
}

.text-input {
  flex: 1;
  height: 68rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  background: #FFFFFF;
  font-size: 28rpx;
  color: #333333;
}

.slider-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4rpx;
}

.slider-value {
  font-size: 26rpx;
  color: #1677FF;
  font-weight: 500;
}

.slider {
  margin: 6rpx 0 20rpx;
}

.swatch-list {
  display: flex;
  flex: 1;
  gap: 20rpx;
}

.swatch {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
  transition: transform 0.15s;
}

.swatch-active {
  transform: scale(1.2);
  box-shadow: 0 0 0 6rpx rgba(22, 119, 255, 0.2), 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.save-btn {
  margin-top: 28rpx;
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  background: #1677FF;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
}

.save-btn::after {
  border: none;
}

.save-btn[disabled] {
  background: #A0C4FF;
}
