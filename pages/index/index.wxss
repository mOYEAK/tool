page {
  min-height: 100vh;
  background: #F7F8FA;
}

.page {
  min-height: 100vh;
  padding: 36rpx 32rpx 56rpx;
}

.header {
  padding: 20rpx 4rpx 36rpx;
}

.title {
  color: #111111;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  margin-top: 12rpx;
  color: #7A7F87;
  font-size: 26rpx;
  line-height: 1.5;
}

.section {
  padding: 32rpx 28rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
}

.section-title {
  color: #333333;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32rpx 20rpx;
  margin-top: 32rpx;
}

.tool-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 152rpx;
  padding: 12rpx 4rpx;
  border-radius: 16rpx;
  background: #FAFBFC;
}

.tool-card:active {
  background: #EEF4FF;
}

.tool-icon {
  height: 72rpx;
  font-size: 56rpx;
  line-height: 72rpx;
}

.tool-name {
  margin-top: 12rpx;
  color: #111111;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
}
