<view class="page">
  <view class="header">
    <view class="title">万能工具箱</view>
    <view class="subtitle">日常图片处理、二维码与签名工具</view>
  </view>

  <view class="search-box">
    <text class="search-icon">⌕</text>
    <text class="search-placeholder">搜索你想要的工具</text>
  </view>

  <view class="section">
    <view class="section-title">图像处理</view>
    <view class="tool-grid">
      <view class="tool-card" bindtap="MapsToGridCut">
        <view class="tool-icon">🖼️</view>
        <view class="tool-name">九宫格切图</view>
      </view>

      <view class="tool-card" bindtap="MapsToLongPic">
        <view class="tool-icon">📜</view>
        <view class="tool-name">长图拼接</view>
      </view>

      <view class="tool-card" bindtap="MapsToImageCompress">
        <view class="tool-icon">🗜️</view>
        <view class="tool-name">图片压缩</view>
      </view>

      <view class="tool-card" bindtap="MapsToSignature">
        <view class="tool-icon">✍️</view>
        <view class="tool-name">手写签名</view>
      </view>

      <view class="tool-card" bindtap="MapsToQrCode">
        <view class="tool-icon">🔲</view>
        <view class="tool-name">二维码工具</view>
      </view>

      <view class="tool-card" bindtap="MapsToMockupWallpaper">
        <view class="tool-icon">📱</view>
        <view class="tool-name">带壳壁纸</view>
      </view>
    </view>
  </view>
</view>
