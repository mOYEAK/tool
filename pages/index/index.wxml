<view class="page">
  <view class="header">
    <view class="title">万能工具箱</view>
    <view class="subtitle">日常图片处理、二维码与签名工具</view>
  </view>

  <view class="search-box">
    <text class="search-icon">⌕</text>
    <input
      class="search-input"
      value="{{keyword}}"
      placeholder="搜索你想要的工具"
      confirm-type="search"
      bindinput="onSearchInput"
    />
    <text wx:if="{{keyword}}" class="clear-icon" bindtap="clearSearch">×</text>
  </view>

  <block wx:if="{{hasTools}}">
    <view
      wx:for="{{toolGroups}}"
      wx:key="category"
      class="section"
    >
      <view class="section-title">{{item.category}}</view>
      <view class="tool-grid">
        <view
          wx:for="{{item.tools}}"
          wx:for-item="tool"
          wx:key="key"
          class="tool-card"
          data-tool="{{tool}}"
          bindtap="MapsToTool"
        >
          <view class="tool-icon">{{tool.icon}}</view>
          <view class="tool-name">{{tool.name}}</view>
        </view>
      </view>
    </view>
  </block>

  <view wx:else class="empty-state">
    暂未找到相关工具
  </view>
</view>
