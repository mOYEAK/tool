<view class="page">
  <!-- 选图 -->
  <view class="top-bar">
    <button class="choose-btn" bindtap="chooseImage">
      {{imagePath ? '重新选择照片' : '选择照片'}}
    </button>
  </view>

  <!-- 图片预览 -->
  <view class="preview-section" wx:if="{{imagePath && !resultPath}}">
    <view class="preview-wrapper">
      <image class="preview-image" src="{{imagePath}}" mode="widthFix" />
      <view class="crop-guide" style="aspect-ratio: {{currentSize.ratio}}"></view>
    </view>

    <!-- 底色选择 -->
    <view class="control-group">
      <text class="control-label">背景色</text>
      <view class="color-swatches">
        <view
          wx:for="{{bgColors}}"
          wx:key="value"
          class="swatch {{bgColor === item.value ? 'active' : ''}}"
          style="background: {{item.color}}"
          data-color="{{item.value}}"
          bindtap="selectBgColor"
        >
          <text wx:if="{{bgColor === item.value}}" class="swatch-check">✓</text>
        </view>
      </view>
    </view>

    <!-- 尺寸选择 -->
    <view class="control-group">
      <text class="control-label">照片尺寸</text>
      <view class="size-options">
        <view
          wx:for="{{photoSizes}}"
          wx:key="value"
          class="size-option {{currentSize.value === item.value ? 'active' : ''}}"
          data-size="{{item}}"
          bindtap="selectSize"
        >
          <text class="size-label">{{item.label}}</text>
          <text class="size-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <!-- 生成按钮 -->
    <button
      class="generate-btn"
      bindtap="startGenerate"
      loading="{{isGenerating}}"
      disabled="{{isGenerating}}"
    >生成证件照</button>
  </view>

  <!-- 生成中 -->
  <view class="generating-hint" wx:if="{{isGenerating}}">
    <view class="hint-icon">🖼️</view>
    <view class="hint-text">正在抠图换底色...</view>
    <view class="hint-sub">调用人像分割 API，请稍候</view>
  </view>

  <!-- 结果展示 -->
  <view class="result-section" wx:if="{{resultPath}}">
    <view class="result-header">
      <text class="result-title">生成结果</text>
      <text class="result-label">{{currentSize.label}}</text>
    </view>

    <view class="result-preview">
      <image class="result-image" src="{{resultPath}}" mode="widthFix" />
    </view>

    <view class="bottom-actions">
      <button class="action-btn save-btn" bindtap="saveResult">
        <text>💾 保存到相册</text>
      </button>
      <button class="action-btn retry-btn" bindtap="resetPage">
        <text>🔄 重新生成</text>
      </button>
    </view>

    <!-- 高清美颜占位 -->
    <view class="upgrade-hint">
      <text class="upgrade-text">高清美颜 · 即将开放</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!imagePath && !isGenerating}}">
    <view class="empty-icon">📸</view>
    <view class="empty-title">证件照生成</view>
    <view class="empty-desc">上传正面人像照片，自动抠图换底色。\n支持白底、蓝底、红底，1 寸 / 2 寸规格。</view>
  </view>
</view>

<!-- 隐藏 Canvas -->
<canvas
  type="2d"
  id="photoCanvas"
  class="hidden-canvas"
  style="width: 600px; height: 800px;"
></canvas>