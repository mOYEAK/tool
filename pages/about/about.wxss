page {
  min-height: 100vh;
  background: #F7F8FA;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
}

.profile-card,
.section {
  background: #FFFFFF;
  border-radius: 20rpx;
}

.profile-card {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  padding: 36rpx 32rpx;
}

.app-logo {
  width: 96rpx;
  height: 96rpx;
  margin-right: 24rpx;
  font-size: 56rpx;
  line-height: 96rpx;
  text-align: center;
  background: #EEF4FF;
  border-radius: 24rpx;
}

.app-name {
  color: #111111;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.4;
}

.app-desc {
  margin-top: 6rpx;
  color: #7A7F87;
  font-size: 26rpx;
}

.section {
  margin-bottom: 28rpx;
  padding: 32rpx;
}

.section-title {
  margin-bottom: 14rpx;
  color: #111111;
  font-size: 32rpx;
  font-weight: 600;
}

.paragraph {
  color: #5F6673;
  font-size: 28rpx;
  line-height: 1.8;
}

.paragraph + .paragraph {
  margin-top: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 76rpx;
  color: #111111;
  font-size: 28rpx;
  border-bottom: 1rpx solid #EEF0F3;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-extra {
  color: #8A8F99;
  font-size: 26rpx;
}

.email {
  margin-top: 18rpx;
  color: #1677FF;
  font-size: 28rpx;
}
