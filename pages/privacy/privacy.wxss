page {
  min-height: 100vh;
  background: #F7F8FA;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
}

.section {
  margin-bottom: 28rpx;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
}

.title {
  color: #111111;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.4;
}

.desc,
.paragraph {
  color: #5F6673;
  font-size: 28rpx;
  line-height: 1.8;
}

.desc {
  margin-top: 16rpx;
}

.section-title {
  margin-bottom: 14rpx;
  color: #111111;
  font-size: 32rpx;
  font-weight: 600;
}

.paragraph + .paragraph {
  margin-top: 12rpx;
}
