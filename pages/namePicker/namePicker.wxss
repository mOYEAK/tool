page {
  min-height: 100vh;
  background: #F7F8FA;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
}

.section {
  margin-bottom: 28rpx;
  padding: 32rpx 28rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
}

.section-title {
  margin-bottom: 24rpx;
  color: #111111;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.4;
}

.name-input {
  width: 100%;
  min-height: 360rpx;
  padding: 24rpx;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.6;
  background: #F7F8FA;
  border-radius: 16rpx;
}

.tips,
.count-tip {
  margin-top: 14rpx;
  color: #8A8F99;
  font-size: 24rpx;
  line-height: 1.5;
}

.count-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.count-label {
  color: #111111;
  font-size: 30rpx;
  font-weight: 500;
}

.stepper {
  display: flex;
  align-items: center;
  overflow: hidden;
  border: 1rpx solid #DADDE3;
  border-radius: 12rpx;
}

.step-button {
  width: 72rpx;
  height: 72rpx;
  color: #1677FF;
  font-size: 34rpx;
  line-height: 72rpx;
  text-align: center;
  background: #EEF4FF;
}

.count-input {
  width: 92rpx;
  height: 72rpx;
  color: #111111;
  font-size: 30rpx;
  text-align: center;
  background: #FFFFFF;
}

.primary-button,
.plain-button,
.copy-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.primary-button {
  color: #FFFFFF;
  background: #1677FF;
}

.plain-button {
  margin-top: 20rpx;
  color: #111111;
  background: #FFFFFF;
  border: 1rpx solid #DADDE3;
}

.copy-button {
  margin-top: 24rpx;
  color: #FFFFFF;
  background: #07C160;
}

.result-list {
  padding: 8rpx 0;
}

.result-item {
  margin-bottom: 16rpx;
  padding: 22rpx 24rpx;
  color: #111111;
  font-size: 30rpx;
  background: #F7F8FA;
  border-radius: 14rpx;
}

.result-item:last-child {
  margin-bottom: 0;
}
