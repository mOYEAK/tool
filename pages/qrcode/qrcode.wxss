page {
  min-height: 100vh;
  background: #F7F8FA;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
}

.section {
  margin-bottom: 32rpx;
  padding: 32rpx 28rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
}

.section-title {
  margin-bottom: 24rpx;
  color: #111111;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.4;
}

.text-input {
  width: 100%;
  min-height: 220rpx;
  padding: 24rpx;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.6;
  background: #F7F8FA;
  border-radius: 16rpx;
}

.primary-button,
.secondary-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.primary-button {
  margin-top: 24rpx;
  color: #FFFFFF;
  background: #1677FF;
}

.secondary-button {
  margin-top: 24rpx;
  color: #1677FF;
  background: #EEF4FF;
}

.qr-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 32rpx;
}

.qr-image {
  width: 400rpx;
  height: 400rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #EEF0F3;
  border-radius: 16rpx;
}

.decode-result {
  min-height: 180rpx;
  margin-top: 24rpx;
  padding: 24rpx;
  color: #111111;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
  background: #F7F8FA;
  border-radius: 16rpx;
}

.placeholder-text {
  color: #8A8F99;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
}
