<view class="page">
  <view class="section">
    <view class="section-title">二维码生成</view>
    <textarea
      class="text-input"
      value="{{qrText}}"
      placeholder="请输入要生成二维码的文本或网址"
      maxlength="-1"
      bindinput="onQrTextInput"
    ></textarea>
    <button class="primary-button" bindtap="generateQrCode">生成二维码</button>

    <view wx:if="{{qrImagePath}}" class="qr-preview">
      <image class="qr-image" src="{{qrImagePath}}" mode="aspectFit" show-menu-by-longpress />
      <button class="secondary-button" bindtap="saveQrCode">保存到相册</button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">二维码解码</view>
    <button class="primary-button" bindtap="chooseQrImage">从相册选择二维码解码</button>

    <view class="decode-result">
      <text wx:if="{{scanResult}}" selectable>{{scanResult}}</text>
      <text wx:else class="placeholder-text">解析结果会显示在这里</text>
    </view>

    <button
      wx:if="{{scanResult}}"
      class="secondary-button"
      bindtap="copyScanResult"
    >
      一键复制
    </button>
  </view>

  <canvas id="qrCanvas" type="2d" class="hidden-canvas"></canvas>
  <canvas id="decodeCanvas" type="2d" class="hidden-canvas"></canvas>
</view>
