page {
  min-height: 100vh;
  background: #F7F8FA;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
}

.section {
  margin-bottom: 28rpx;
  padding: 32rpx 28rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  margin-bottom: 24rpx;
  color: #111111;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.4;
}

.section-header .section-title {
  margin-bottom: 0;
}

.type-tabs {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.type-tab {
  height: 76rpx;
  color: #666666;
  font-size: 28rpx;
  line-height: 76rpx;
  text-align: center;
  background: #F7F8FA;
  border-radius: 14rpx;
}

.type-active {
  color: #1677FF;
  font-weight: 600;
  background: #EEF4FF;
}

.field-input,
.remark-input {
  width: 100%;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
  color: #111111;
  font-size: 28rpx;
  background: #F7F8FA;
  border-radius: 14rpx;
}

.field-input {
  height: 84rpx;
}

.remark-input {
  min-height: 140rpx;
  padding-top: 22rpx;
  line-height: 1.6;
}

.add-link {
  color: #1677FF;
  font-size: 28rpx;
}

.item-card {
  margin-top: 24rpx;
  padding: 22rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
}

.item-row {
  display: grid;
  grid-template-columns: 1fr 1fr 150rpx;
  gap: 14rpx;
  align-items: center;
}

.small-input {
  height: 76rpx;
  padding: 0 18rpx;
  color: #111111;
  font-size: 26rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
}

.subtotal {
  color: #111111;
  font-size: 24rpx;
  text-align: right;
}

.delete-item {
  margin-top: 16rpx;
  color: #E5484D;
  font-size: 26rpx;
  text-align: right;
}

.total-row {
  display: flex;
  justify-content: space-between;
  margin-top: 28rpx;
  padding-top: 24rpx;
  color: #111111;
  font-size: 34rpx;
  font-weight: 700;
  border-top: 1rpx solid #EEF0F3;
}

.primary-button,
.plain-button,
.save-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.primary-button {
  color: #FFFFFF;
  background: #1677FF;
}

.plain-button {
  margin-top: 20rpx;
  color: #111111;
  background: #FFFFFF;
  border: 1rpx solid #DADDE3;
}

.save-button {
  margin-top: 24rpx;
  color: #FFFFFF;
  background: #07C160;
}

.result-section {
  margin-top: 28rpx;
}

.result-image {
  display: block;
  width: 100%;
  height: 760rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
}

.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
}
