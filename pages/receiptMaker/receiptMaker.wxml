<view class="page">
  <view class="section">
    <view class="section-title">单据类型</view>
    <view class="type-tabs">
      <view
        class="type-tab {{docType === 'quote' ? 'type-active' : ''}}"
        data-type="quote"
        bindtap="changeDocType"
      >
        报价单
      </view>
      <view
        class="type-tab {{docType === 'receipt' ? 'type-active' : ''}}"
        data-type="receipt"
        bindtap="changeDocType"
      >
        收据
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">基础信息</view>
    <input class="field-input" value="{{shopName}}" placeholder="店名 / 个人名" data-field="shopName" bindinput="onFieldInput" />
    <input class="field-input" value="{{clientName}}" placeholder="客户名" data-field="clientName" bindinput="onFieldInput" />
    <input class="field-input" value="{{date}}" placeholder="日期，例如 2026-06-06" data-field="date" bindinput="onFieldInput" />
    <textarea class="remark-input" value="{{remark}}" placeholder="备注，可不填" data-field="remark" bindinput="onFieldInput"></textarea>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">项目明细</view>
      <view class="add-link" bindtap="addItem">添加项目</view>
    </view>

    <view wx:for="{{items}}" wx:key="id" class="item-card">
      <input class="field-input" value="{{item.name}}" placeholder="项目名称" data-index="{{index}}" data-field="name" bindinput="onItemInput" />
      <view class="item-row">
        <input class="small-input" type="digit" value="{{item.quantity}}" placeholder="数量" data-index="{{index}}" data-field="quantity" bindinput="onItemInput" />
        <input class="small-input" type="digit" value="{{item.price}}" placeholder="单价" data-index="{{index}}" data-field="price" bindinput="onItemInput" />
        <view class="subtotal">￥{{item.subtotalText}}</view>
      </view>
      <view wx:if="{{items.length > 1}}" class="delete-item" data-index="{{index}}" bindtap="deleteItem">删除</view>
    </view>

    <view class="total-row">
      <text>合计</text>
      <text>￥{{totalText}}</text>
    </view>
  </view>

  <button class="primary-button" bindtap="generateReceiptImage" disabled="{{isGenerating}}">生成图片单据</button>
  <button class="plain-button" bindtap="clearForm">清空表单</button>

  <view wx:if="{{resultPath}}" class="section result-section">
    <view class="section-title">生成结果</view>
    <image class="result-image" src="{{resultPath}}" mode="aspectFit" />
    <button class="save-button" bindtap="saveResult" disabled="{{isSaving}}">保存到相册</button>
  </view>

  <canvas id="receiptCanvas" type="2d" class="hidden-canvas"></canvas>
</view>
