<view class="page">
  <view class="canvas-wrap">
    <canvas
      type="2d"
      id="signCanvas"
      class="sign-canvas"
      disable-scroll="true"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    ></canvas>
  </view>

  <view class="toolbar">
    <button class="clear-button" bindtap="clearCanvas">清除重写</button>
    <button class="save-button" bindtap="saveSignature">保存签名</button>
  </view>
</view>
