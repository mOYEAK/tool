page {
  height: 100vh;
  overflow: hidden;
  background: #F7F8FA;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.canvas-wrap {
  flex: 1;
  margin: 24rpx;
  overflow: hidden;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(20, 28, 40, 0.06);
}

.sign-canvas {
  width: 100%;
  height: 100%;
}

.toolbar {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #F7F8FA;
}

.clear-button,
.save-button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.clear-button {
  color: #111111;
  background: #FFFFFF;
  border: 1rpx solid #DADDE3;
}

.save-button {
  color: #FFFFFF;
  background: #1677FF;
}
