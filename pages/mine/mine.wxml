<view class="page">
  <view class="profile-card">
    <view class="app-logo">🧰</view>
    <view>
      <view class="app-name">万能工具箱</view>
      <view class="app-desc">轻量、纯本地、即开即用</view>
    </view>
  </view>

  <view class="ad-placeholder">
    <view class="ad-title">广告位预留</view>
    <view class="ad-desc">流量主开通后展示，不影响当前免费工具使用</view>
  </view>

  <view class="section">
    <view class="section-title">使用记录</view>
    <view class="row" bindtap="showComingSoon">
      <text>最近使用</text>
      <text class="row-extra">暂未开放</text>
    </view>
    <view class="row" bindtap="showComingSoon">
      <text>导出记录</text>
      <text class="row-extra">本地记录占位</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">使用与反馈</view>
    <button class="plain-row" open-type="feedback">意见反馈</button>
    <button class="plain-row" open-type="contact">联系客服</button>
    <view class="row" bindtap="copyEmail">
      <text>联系邮箱</text>
      <text class="row-extra">support@example.com</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">关于</view>
    <view class="row" bindtap="showComingSoon">
      <text>隐私协议</text>
      <text class="row-extra">本地处理优先</text>
    </view>
    <view class="row" bindtap="showComingSoon">
      <text>关于我们</text>
      <text class="row-extra">万能工具箱</text>
    </view>
    <view class="row">
      <text>当前版本</text>
      <text class="row-extra">V1.0</text>
    </view>
  </view>
</view>
