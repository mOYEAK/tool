page {
  background: #F7F8FA;
  padding-bottom: 60rpx;
}

/* 顶栏 */
.top-bar {
  padding: 24rpx 32rpx;
}

.choose-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  background: #1677FF;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
}

.choose-btn::after {
  border: none;
}

/* 图片预览 */
.preview-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.preview-image {
  width: 100%;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(20, 28, 40, 0.08);
}

.action-row {
  margin-top: 24rpx;
}

.ocr-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #1677FF, #36CFC9);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
}

.ocr-btn::after {
  border: none;
}

.ocr-btn[disabled] {
  background: #D9D9D9;
}

/* 识别中 */
.recognizing-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
}

.hint-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(0.95); }
}

.hint-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.hint-sub {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 结果区 */
.result-section {
  padding: 0 32rpx;
}

.result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.result-count {
  font-size: 24rpx;
  color: #1677FF;
  background: rgba(22, 119, 255, 0.08);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.result-textarea {
  width: 100%;
  min-height: 300rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(20, 28, 40, 0.04);
}

/* 底部操作 */
.bottom-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.action-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.action-btn::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
}

.copy-btn {
  background: #FFFFFF;
  color: #333333;
  border: 2rpx solid #E5E5E5;
}

.export-btn {
  background: #1677FF;
  color: #FFFFFF;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-left: 48rpx;
  padding-right: 48rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
  white-space: pre-line;
}

/* 隐藏 Canvas */
.hidden-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
}