page {
  min-height: 100vh;
  background: #F7F8FA;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
}

.primary-button,
.save-button {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
}

.primary-button {
  color: #FFFFFF;
  background: #1677FF;
}

.save-button {
  margin-top: 32rpx;
  color: #FFFFFF;
  background: #07C160;
}

.image-list {
  height: 920rpx;
  margin-top: 32rpx;
  padding: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
}

.image-item {
  position: relative;
  margin-bottom: 24rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: #EEF0F3;
}

.image-item:last-child {
  margin-bottom: 0;
}

.preview-image {
  display: block;
  width: 100%;
}

.delete-button {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  color: #FFFFFF;
  font-size: 40rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
}

.empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #8A8F99;
  font-size: 28rpx;
  text-align: center;
}

.splice-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
}
