<view class="page">
  <view class="section">
    <view class="section-title">海报模板</view>
    <view class="template-grid">
      <view
        wx:for="{{templates}}"
        wx:key="value"
        class="template-card {{selectedTemplate === item.value ? 'template-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="selectTemplate"
      >
        <view class="template-preview" style="background: {{item.preview}};">
          <view class="template-mark">{{item.icon}}</view>
        </view>
        <view class="template-name">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">海报内容</view>
    <input class="field-input" value="{{title}}" placeholder="活动标题，例如 周末手作体验课" data-field="title" bindinput="onFieldInput" />
    <input class="field-input" value="{{subtitle}}" placeholder="副标题，例如 限时开放报名" data-field="subtitle" bindinput="onFieldInput" />
    <input class="field-input" value="{{time}}" placeholder="时间，例如 6月18日 14:00" data-field="time" bindinput="onFieldInput" />
    <input class="field-input" value="{{location}}" placeholder="地点，例如 城市书房 2 楼" data-field="location" bindinput="onFieldInput" />
    <input class="field-input" value="{{organizer}}" placeholder="主办方 / 联系方式" data-field="organizer" bindinput="onFieldInput" />
    <textarea class="remark-input" value="{{remark}}" placeholder="备注，可不填" data-field="remark" bindinput="onFieldInput"></textarea>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">主视觉图片</view>
      <view wx:if="{{visualPath}}" class="remove-link" bindtap="removeVisual">移除</view>
    </view>

    <view wx:if="{{visualPath}}" class="visual-wrap">
      <image class="visual-image" src="{{visualPath}}" mode="aspectFill" />
    </view>
    <view wx:else class="empty-visual" bindtap="chooseVisual">
      <view class="empty-icon">＋</view>
      <view class="empty-text">上传图片，可不选</view>
    </view>
    <button class="plain-button" bindtap="chooseVisual">选择图片</button>
  </view>

  <button class="primary-button" bindtap="generatePoster" disabled="{{isGenerating}}">一键生成海报</button>
  <button class="plain-button bottom-button" bindtap="clearDraft">清空草稿</button>

  <view wx:if="{{resultPath}}" class="section result-section">
    <view class="section-header">
      <view class="section-title">生成结果</view>
      <view class="preview-link" bindtap="previewPoster">预览</view>
    </view>
    <image class="result-image" src="{{resultPath}}" mode="aspectFit" bindtap="previewPoster" />
    <button class="save-button" bindtap="savePoster" disabled="{{isSaving}}">保存到相册</button>
  </view>

  <canvas id="posterCanvas" type="2d" class="hidden-canvas"></canvas>
</view>
